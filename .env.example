# These are set in the Netlify dashboard (Site settings -> Environment variables),
# NOT committed. This file just documents what is needed.

# From Supabase: Project Settings -> API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SECRET — server only, never in the browser

# From football-data.org (free account): your API token
FOOTBALL_DATA_TOKEN=your-football-data-token
